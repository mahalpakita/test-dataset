  "content_features": [
    {
      "title": "Familiar wallet checkout for Amazon customers",
      "description": "Shoppers can use the payment methods and shipping addresses already saved in their Amazon account, reducing manual entry at checkout."
    },
    {
      "title": "Reconciliation and reporting",
      "description": "Amazon Pay provides transaction reporting to support reconciliation; align order IDs and payment references between your ecommerce platform, PSP, and Amazon Pay views."
    },
    {
      "title": "Authorization outcomes and declines",
      "description": "Like any payment method, transactions can be authorized or declined based on buyer, instrument, and risk signals. Monitor decline reasons and compare wallet performance vs. other tender types."
    },
    {
      "title": "Disputes and chargeback handling",
      "description": "Dispute and customer inquiry processes may differ from card processing flows. Ensure your support and evidence processes cover wallet-originated transactions."
    },
    {
      "title": "Refunds and order adjustments",
      "description": "Operational flows such as refunds are typically handled through the Amazon Pay merchant tools and/or your connected PSP workflow, depending on integration."
    }
  ],
  "tip": "If you see higher declines on Amazon Pay than other methods, verify your order totals, currency, shipping address, and shopper details before blaming issuer behavior.",
